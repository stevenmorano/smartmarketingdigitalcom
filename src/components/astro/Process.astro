---
// src/components/astro/Process.astro
---

<section class="process section-light" id="process">
  <div class="container">
    
    <!-- Section Header -->
    <div class="section-header">
      <span class="sub-title">My Process</span>
      <h2 class="main-title">A Simple, Proven 4-Step Process</h2>
    </div>

    <!-- Process Steps Grid -->
    <div class="steps-grid">
      
      <!-- Step 1: Audit & Strategy -->
      <div class="step-card">
        <div class="step-badge">1</div>
        <div class="step-icon-container">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="step-svg">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </div>
        <h3 class="step-heading">Audit & Strategy</h3>
        <p class="step-desc">
          I analyze your current business, offering, and marketing channels to identify immediate opportunities and build a clear, data-driven system blueprint.
        </p>
      </div>

      <!-- Step 2: Build the System -->
      <div class="step-card">
        <div class="step-badge">2</div>
        <div class="step-icon-container">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="step-svg">
            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path>
          </svg>
        </div>
        <h3 class="step-heading">Build the System</h3>
        <p class="step-desc">
          I build or optimize your landing pages, CRM pipelines, ad campaigns, and data tracking layers — engineered from the ground up for conversion and scale.
        </p>
      </div>

      <!-- Step 3: Launch & Optimize -->
      <div class="step-card">
        <div class="step-badge">3</div>
        <div class="step-icon-container">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="step-svg">
            <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"></path>
          </svg>
        </div>
        <h3 class="step-heading">Launch & Optimize</h3>
        <p class="step-desc">
          We push the new system live. I monitor metrics in real time, employing AI bid adjustments and split-tests to reduce client acquisition costs.
        </p>
      </div>

      <!-- Step 4: Measure & Scale -->
      <div class="step-card">
        <div class="step-badge">4</div>
        <div class="step-icon-container">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="step-svg">
            <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline>
            <polyline points="16 7 22 7 22 13"></polyline>
          </svg>
        </div>
        <h3 class="step-heading">Measure & Scale</h3>
        <p class="step-desc">
          I generate clear attribution reports mapping exactly where leads and sales originate, helping us double down on channels that drive scalable growth.
        </p>
      </div>

    </div>

  </div>
</section>

<style>
  .process {
    background-color: var(--color-bg-light-deep);
    border-bottom: 1px solid var(--color-border-light);
  }

  .section-header {
    text-align: center;
    max-width: 650px;
    margin: 0 auto 4.5rem;
  }

  .sub-title {
    font-family: var(--font-headings);
    color: var(--color-primary);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: inline-block;
    margin-bottom: 0.5rem;
  }

  .main-title {
    font-size: clamp(1.8rem, 3.5vw, 2.5rem);
    color: var(--color-text-light-primary);
    letter-spacing: -0.02em;
  }

  /* Steps Grid & Cards */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    position: relative;
  }

  .step-card {
    background: var(--color-bg-light-card);
    border: 1px solid var(--color-border-light);
    border-radius: 16px;
    padding: 2.25rem 1.5rem 2rem;
    position: relative;
    transition: var(--transition-smooth);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .step-card:hover {
    transform: translateY(-4px);
    border-color: rgba(59, 130, 246, 0.2);
    box-shadow: 0 15px 30px rgba(59, 130, 246, 0.03), var(--shadow-md);
  }

  .step-badge {
    position: absolute;
    top: -12px;
    left: 1.5rem;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--color-primary);
    color: #ffffff;
    font-family: var(--font-headings);
    font-size: 0.75rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 10px rgba(59, 130, 246, 0.35);
    z-index: 2;
  }

  .step-icon-container {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 8px;
    background: rgba(59, 130, 246, 0.05);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    transition: var(--transition-smooth);
  }

  .step-card:hover .step-icon-container {
    background: rgba(59, 130, 246, 0.1);
    transform: scale(1.05);
  }

  .step-svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  .step-heading {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text-light-primary);
    margin-bottom: 0.75rem;
  }

  .step-desc {
    font-size: 0.85rem;
    color: var(--color-text-light-secondary);
    line-height: 1.55;
  }

  /* Responsive styling */
  @media (max-width: 992px) {
    .steps-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }
  }

  @media (max-width: 640px) {
    .steps-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
