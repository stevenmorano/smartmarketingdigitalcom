---
// src/components/astro/Framework.astro
---

<section class="framework section-dark" id="framework">
  <div class="container">
    
    <!-- Section Header -->
    <div class="section-header reveal-item">
      <span class="sub-title">My Framework</span>
      <h2 class="main-title">The AI-Enhanced Marketing System</h2>
      <p class="section-desc">
        A connected system where AI, automation, and data work together to attract, nurture, and convert more of the right customers — on autopilot.
      </p>
    </div>

    <!-- Framework Horizontal Flow -->
    <div class="flow-container">
      
      <!-- Step 1: Traffic Sources -->
      <div class="flow-node reveal-item">
        <div class="node-num">01</div>
        <h3 class="node-title">Traffic Sources</h3>
        <div class="node-logo-row">
          <span class="logo-mini logo-google" title="Google Search">G</span>
          <span class="logo-mini logo-meta" title="Meta Ads">M</span>
          <span class="logo-mini logo-email" title="Email Marketing">✉</span>
        </div>
        <ul class="node-list">
          <li>Paid Ad Search</li>
          <li>Social Audiences</li>
          <li>Email Channels</li>
          <li>Organic Traffic</li>
        </ul>
      </div>

      <div class="flow-arrow reveal-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </div>

      <!-- Step 2: Landing Pages -->
      <div class="flow-node reveal-item">
        <div class="node-num">02</div>
        <h3 class="node-title">Landing Pages</h3>
        <div class="node-visual-box">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="box-svg">
            <rect x="3" y="3" width="18" height="18" rx="2"></rect>
            <line x1="3" y1="9" x2="21" y2="9"></line>
            <line x1="9" y1="21" x2="9" y2="9"></line>
          </svg>
        </div>
        <ul class="node-list">
          <li>Optimized Layouts</li>
          <li>High-Intent Captures</li>
          <li>Compelling Offers</li>
        </ul>
      </div>

      <div class="flow-arrow reveal-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </div>

      <!-- Step 3: CRM & Automation -->
      <div class="flow-node reveal-item">
        <div class="node-num">03</div>
        <h3 class="node-title">CRM & Automation</h3>
        <div class="node-visual-box">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="box-svg">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
            <circle cx="9" cy="7" r="4"></circle>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
          </svg>
        </div>
        <ul class="node-list">
          <li>CRM Lead Sync</li>
          <li>Nurture Workflows</li>
          <li>RFM Segmentation</li>
        </ul>
      </div>

      <div class="flow-arrow reveal-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </div>

      <!-- Step 4: AI Optimization -->
      <div class="flow-node highlight-node reveal-item">
        <div class="node-glow-border"></div>
        <div class="node-num">04</div>
        <h3 class="node-title">AI Optimization</h3>
        <div class="node-visual-box text-blue">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="box-svg">
            <path d="M12 2a10 10 0 0 1 7.54 16.59A10 10 0 1 1 4.46 5.41 10 10 0 0 1 12 2z"></path>
            <path d="M12 6v12M6 12h12"></path>
          </svg>
        </div>
        <ul class="node-list">
          <li>Smarter Bid Logic</li>
          <li>Dynamic Copy / AI</li>
          <li>Predictive Insights</li>
        </ul>
      </div>

      <div class="flow-arrow reveal-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </div>

      <!-- Step 5: Reporting Dashboard -->
      <div class="flow-node reveal-item">
        <div class="node-num">05</div>
        <h3 class="node-title">Reporting Hub</h3>
        <div class="node-visual-box">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="box-svg">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="9" y1="9" x2="15" y2="9"></line>
            <line x1="9" y1="15" x2="15" y2="15"></line>
          </svg>
        </div>
        <ul class="node-list">
          <li>Attribution Model</li>
          <li>Core KPI Tracking</li>
          <li>LTV & ROI Audits</li>
        </ul>
      </div>

      <div class="flow-arrow reveal-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </div>

      <!-- Step 6: Sales / Revenue Growth -->
      <div class="flow-node reveal-item">
        <div class="node-num">06</div>
        <h3 class="node-title">Revenue Growth</h3>
        <div class="node-visual-box text-teal">
          <span style="font-family: var(--font-headings); font-weight: 800; font-size: 1.25rem;">$</span>
        </div>
        <ul class="node-list">
          <li>More Customers</li>
          <li>Higher Customer LTV</li>
          <li>Scalable Marketing</li>
        </ul>
      </div>

    </div>

    <!-- Return Loop Visual -->
    <div class="feedback-loop reveal-item">
      <svg class="loop-svg" viewBox="0 0 1000 120" fill="none" preserveAspectRatio="none">
        <!-- Loop line curving from bottom right back to bottom left -->
        <path d="M 900 20 C 900 80, 100 80, 100 20" stroke="rgba(59, 130, 246, 0.4)" stroke-width="2" stroke-dasharray="6,6" id="loop-path" />
        <path d="M 97 18 L 100 28 L 105 20 Z" fill="rgba(59, 130, 246, 0.6)" />
      </svg>
      <div class="loop-text-label">Continuous Learning & Optimization Loop</div>
    </div>

  </div>
</section>

<style>
  .framework {
    background-color: var(--color-bg-dark-deep);
    border-bottom: 1px solid var(--color-border-dark);
  }

  .section-header {
    text-align: center;
    max-width: 650px;
    margin: 0 auto 4rem;
  }

  .sub-title {
    font-family: var(--font-headings);
    color: var(--color-primary);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: inline-block;
    margin-bottom: 0.5rem;
  }

  .main-title {
    font-size: clamp(1.8rem, 3.5vw, 2.5rem);
    color: var(--color-text-dark-primary);
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .section-desc {
    color: var(--color-text-dark-secondary);
    font-size: 1rem;
  }

  /* Flow Diagram Container */
  .flow-container {
    display: flex;
    align-items: stretch;
    justify-content: space-between;
    gap: 0.5rem;
    position: relative;
  }

  .flow-node {
    background: rgba(13, 18, 34, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    padding: 1.5rem 1.25rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    transition: var(--transition-smooth);
    min-width: 150px;
  }

  .flow-node:hover {
    border-color: rgba(59, 130, 246, 0.2);
    transform: translateY(-2px);
    background: rgba(13, 18, 34, 0.8);
  }

  .highlight-node {
    background: rgba(59, 130, 246, 0.04);
    border-color: rgba(59, 130, 246, 0.2);
  }

  .highlight-node:hover {
    border-color: var(--color-primary);
    box-shadow: 0 0 20px rgba(59, 130, 246, 0.1);
  }

  .node-num {
    font-family: var(--font-headings);
    font-size: 0.75rem;
    font-weight: 800;
    color: var(--color-primary);
    background: rgba(59, 130, 246, 0.1);
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.8rem;
  }

  .node-title {
    font-family: var(--font-headings);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text-dark-primary);
    margin-bottom: 0.8rem;
    min-height: 2.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Visual assets inside nodes */
  .node-logo-row {
    display: flex;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .logo-mini {
    width: 1.35rem;
    height: 1.35rem;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.04);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-text-dark-secondary);
  }

  .logo-google { color: #ea4335; border: 1px solid rgba(234, 67, 53, 0.15); }
  .logo-meta { color: #1877f2; border: 1px solid rgba(24, 119, 242, 0.15); }
  .logo-email { color: var(--color-accent-teal); border: 1px solid rgba(16, 185, 129, 0.15); }

  .node-visual-box {
    width: 1.5rem;
    height: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-dark-secondary);
    margin-bottom: 1rem;
  }

  .box-svg {
    width: 100%;
    height: 100%;
  }

  .text-blue { color: var(--color-primary); }
  .text-teal { color: var(--color-accent-teal); }

  /* Bullet list styling */
  .node-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.75rem;
    color: var(--color-text-dark-secondary);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 0.8rem;
    width: 100%;
    text-align: left;
  }

  .node-list li {
    position: relative;
    padding-left: 0.65rem;
  }

  .node-list li::before {
    content: "•";
    color: var(--color-primary);
    font-size: 0.8rem;
    position: absolute;
    left: 0;
    top: -2px;
  }

  /* Arrows */
  .flow-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.15);
    width: 2rem;
    flex-shrink: 0;
  }

  .flow-arrow svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  /* Feedback Loop */
  .feedback-loop {
    width: 100%;
    margin-top: 2rem;
    text-align: center;
    position: relative;
  }

  .loop-svg {
    width: 100%;
    height: 60px;
    display: block;
  }

  .loop-text-label {
    font-family: var(--font-headings);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 0.5rem;
  }

  /* Animating dashes on feedback path */
  #loop-path {
    stroke-dasharray: 8,8;
    animation: dashLoop 20s linear infinite;
  }

  @keyframes dashLoop {
    to {
      stroke-dashoffset: -200;
    }
  }

  /* Staggered entry animations for flow items */
  .flow-container > .reveal-item:nth-child(1) { transition-delay: 0ms; }
  .flow-container > .reveal-item:nth-child(2) { transition-delay: 100ms; }
  .flow-container > .reveal-item:nth-child(3) { transition-delay: 200ms; }
  .flow-container > .reveal-item:nth-child(4) { transition-delay: 300ms; }
  .flow-container > .reveal-item:nth-child(5) { transition-delay: 400ms; }
  .flow-container > .reveal-item:nth-child(6) { transition-delay: 500ms; }
  .flow-container > .reveal-item:nth-child(7) { transition-delay: 600ms; }
  .flow-container > .reveal-item:nth-child(8) { transition-delay: 700ms; }
  .flow-container > .reveal-item:nth-child(9) { transition-delay: 800ms; }
  .flow-container > .reveal-item:nth-child(10) { transition-delay: 900ms; }
  .flow-container > .reveal-item:nth-child(11) { transition-delay: 1000ms; }

  /* Responsive styling */
  @media (max-width: 1100px) {
    .flow-container {
      overflow-x: auto;
      padding-bottom: 1.5rem;
      justify-content: flex-start;
    }
    .flow-node {
      flex-shrink: 0;
    }
    .feedback-loop {
      display: none; /* Hide complex loop on mobile/overflow scrolls */
    }
  }

  @media (max-width: 768px) {
    .flow-container {
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      overflow-x: visible;
    }
    .flow-node {
      width: 100%;
      max-width: 320px;
    }
    .flow-arrow {
      transform: rotate(90deg);
      padding: 0.25rem 0;
    }
  }
</style>
