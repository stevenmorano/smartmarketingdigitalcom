---
// src/components/astro/Hero.astro
import Dashboard from '../preact/Dashboard.jsx';
---

<section class="hero section-dark">
  <div class="hero-glow animate-pulse-glow"></div>
  <div class="container hero-container">
    
    <!-- Hero Left Column: Copy & CTAs -->
    <div class="hero-content">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        AI-Driven Systems · Direct execution
      </div>
      
      <h1 class="hero-title">
        Scale Your Revenue with Custom AI Marketing <span class="gradient-text">Systems.</span>
      </h1>
      
      <p class="hero-subtitle">
        I build automated customer acquisition engines, high-ROAS paid media campaigns, and custom analytics pipelines for small businesses and e-commerce brands. No agency middlemen—just direct, technical execution that drives leads and sales.
      </p>

      <!-- Key Capabilities Tags -->
      <div class="capabilities-grid">
        <div class="cap-tag">
          <span class="cap-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="cap-svg"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.44 2.5 2.5 0 0 1 0-3.12 3 3 0 0 1 0-4.88 2.5 2.5 0 0 1 0-3.12A2.5 2.5 0 0 1 9.5 2z"></path><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.44 2.5 2.5 0 0 0 0-3.12 3 3 0 0 0 0-4.88 2.5 2.5 0 0 0 0-3.12A2.5 2.5 0 0 0 14.5 2z"></path></svg>
          </span>
          <span>AI-Powered Strategy</span>
        </div>
        <div class="cap-tag">
          <span class="cap-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="cap-svg"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="6"></circle><circle cx="12" cy="12" r="2"></circle></svg>
          </span>
          <span>Paid Media</span>
        </div>
        <div class="cap-tag">
          <span class="cap-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="cap-svg"><rect x="3" y="11" width="18" height="10" rx="2"></rect><circle cx="12" cy="5" r="2"></circle><path d="M12 7v4"></path><line x1="8" y1="16" x2="8" y2="16"></line><line x1="16" y1="16" x2="16" y2="16"></line></svg>
          </span>
          <span>CRM Automation</span>
        </div>
        <div class="cap-tag">
          <span class="cap-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="cap-svg"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>
          </span>
          <span>Analytics</span>
        </div>
        <div class="cap-tag">
          <span class="cap-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="cap-svg"><path d="M22 2l-7.4 7.4M22 2l-2.6 7.8c-.4 1.2-1.3 2.1-2.5 2.5L9 15M22 2l-7.8 2.6c-1.2.4-2.1 1.3-2.5 2.5L9 15M9 15l-4 4M9 15l-1.4 5.6c-.2.7-.9 1.1-1.6.9-.5-.1-.8-.5-.9-.9L6.5 15M9 15L3.4 13.6c-.7-.2-1.1-.9-.9-1.6.1-.5.5-.8.9-.9L9 12.5"></path></svg>
          </span>
          <span>Lead Generation</span>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="hero-actions">
        <button class="btn btn-primary btn-island-cta" data-trigger-intake>
          Request a Free Strategy Review
          <span class="btn-icon-wrapper">
            <svg class="btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </span>
        </button>
        <a href="#framework" class="btn btn-secondary">
          <svg class="btn-play" viewBox="0 0 24 24" fill="currentColor">
            <polygon points="5 3 19 12 5 21 5 3"></polygon>
          </svg>
          See My Systems Framework
        </a>
      </div>

      <!-- Solo Consultant Value Badges -->
      <div class="value-badges">
        <div class="val-badge">
          <div class="val-badge-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="val-svg"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
          </div>
          <div>
            <div class="val-badge-title">Solo Consultant</div>
            <div class="val-badge-desc">Direct access, no middlemen.</div>
          </div>
        </div>
        <div class="val-badge">
          <div class="val-badge-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="val-svg"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polyline></svg>
          </div>
          <div>
            <div class="val-badge-title">Hands-On & Technical</div>
            <div class="val-badge-desc">Strategy + execution.</div>
          </div>
        </div>
        <div class="val-badge">
          <div class="val-badge-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="val-svg"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
          </div>
          <div>
            <div class="val-badge-title">Built for Results</div>
            <div class="val-badge-desc">Systems that scale.</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Hero Right Column: Dynamic Dashboard Island (Double-Bezel Enclosure) -->
    <div class="hero-dashboard">
      <div class="db-outer-shell">
        <div class="db-inner-core">
          <Dashboard client:load />
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 7.5rem; /* Space for fixed Navbar */
    background-image: var(--gradient-hero);
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    top: 15%;
    right: 10%;
    width: 400px;
    height: 400px;
    background: var(--gradient-glow);
    pointer-events: none;
    z-index: 1;
  }

  .hero-container {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 3.5rem;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .hero-badge {
    background: rgba(59, 130, 246, 0.08);
    border: 1px solid rgba(59, 130, 246, 0.2);
    color: var(--color-primary);
    padding: 0.4rem 1rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    background: var(--color-primary);
    border-radius: 50%;
    animation: pulseGlow 2s infinite;
  }

  .hero-title {
    font-size: clamp(2.2rem, 4vw, 3.4rem);
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin-bottom: 1.25rem;
  }

  .hero-subtitle {
    font-size: 1.1rem;
    color: var(--color-text-dark-secondary);
    margin-bottom: 1.75rem;
    max-width: 540px;
  }

  /* Capabilities grid */
  .capabilities-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 2.25rem;
    max-width: 520px;
  }

  .cap-tag {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    padding: 0.35rem 0.8rem;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-dark-secondary);
    display: flex;
    align-items: center;
    gap: 0.4rem;
    transition: var(--transition-smooth);
  }

  .cap-tag:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.12);
    color: var(--color-text-dark-primary);
  }

  .cap-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cap-svg {
    width: 0.95rem;
    height: 0.95rem;
  }

  /* Action buttons */
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .btn-arrow {
    width: 1rem;
    height: 1rem;
    transition: transform 0.3s ease;
  }

  .btn-primary:hover .btn-arrow {
    transform: translateX(4px);
  }

  .btn-play {
    width: 0.85rem;
    height: 0.85rem;
    color: var(--color-primary);
  }

  /* Solo consultant indicators */
  .value-badges {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding-top: 1.5rem;
    width: 100%;
    max-width: 500px;
  }

  .val-badge {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .val-badge-icon {
    width: 2rem;
    height: 2rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .val-svg {
    width: 1rem;
    height: 1rem;
  }

  .val-badge-title {
    font-family: var(--font-headings);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-text-dark-primary);
  }

  .val-badge-desc {
    font-size: 0.75rem;
    color: var(--color-text-dark-secondary);
  }

  /* Right column dashboard container */
  .hero-dashboard {
    width: 100%;
    display: flex;
    justify-content: center;
    perspective: 1000px;
  }

  .db-outer-shell {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    padding: 0.5rem;
    border-radius: 24px;
    width: 100%;
    box-shadow: var(--shadow-card-glow), var(--shadow-lg);
    transition: var(--transition-spring);
  }

  .db-outer-shell:hover {
    border-color: rgba(59, 130, 246, 0.2);
    background: rgba(255, 255, 255, 0.03);
  }

  .db-inner-core {
    border-radius: calc(24px - 0.5rem);
    overflow: hidden;
    width: 100%;
    background: #08080a;
    box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.08);
  }

  /* Responsive Breakpoints */
  @media (max-width: 1024px) {
    .hero-container {
      grid-template-columns: 1fr;
      gap: 3.5rem;
      text-align: center;
    }

    .hero-content {
      align-items: center;
    }

    .hero-badge, .capabilities-grid, .hero-actions {
      justify-content: center;
    }

    .hero-subtitle {
      max-width: 600px;
    }

    .value-badges {
      align-items: center;
      max-width: 100%;
    }

    .val-badge {
      text-align: left;
      max-width: 320px;
      width: 100%;
    }
  }
</style>
