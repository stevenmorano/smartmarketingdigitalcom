---
// src/components/astro/Proof.astro
---

<section class="proof section-light">
  <div class="container">
    
    <!-- Section Header -->
    <div class="section-header">
      <span class="sub-title">Proof That Matters</span>
      <h2 class="main-title">Experience That Delivers Results</h2>
    </div>

    <!-- Metrics Grid -->
    <div class="metrics-grid">
      
      <!-- Metric 1: Experience -->
      <div class="metric-card">
        <div class="metric-visual">10+</div>
        <div class="metric-divider"></div>
        <h3 class="metric-label">Years of Marketing Experience</h3>
      </div>

      <!-- Metric 2: Budgets -->
      <div class="metric-card">
        <div class="metric-visual text-small">Multi-M</div>
        <div class="metric-divider"></div>
        <h3 class="metric-label">Managed Paid Media Budgets</h3>
      </div>

      <!-- Metric 3: Leads -->
      <div class="metric-card">
        <div class="metric-visual">Up to 75%</div>
        <div class="metric-divider"></div>
        <h3 class="metric-label">Past Results Lead Growth</h3>
      </div>

      <!-- Metric 4: Sales -->
      <div class="metric-card">
        <div class="metric-visual">Up to 150%</div>
        <div class="metric-divider"></div>
        <h3 class="metric-label">Past Results Sales Growth</h3>
      </div>

      <!-- Metric 5: Expertise -->
      <div class="metric-card full-width-mobile">
        <div class="metric-visual text-smaller">CRM + Funnel</div>
        <div class="metric-divider"></div>
        <h3 class="metric-label">System Optimization Expertise</h3>
      </div>

    </div>

    <!-- Bottom summary copy -->
    <div class="proof-summary">
      <p class="summary-text">
        I help small businesses and e-commerce brands build smarter marketing systems that generate more leads, improve conversions, and drive measurable, sustainable growth.
      </p>
    </div>

  </div>
</section>

<style>
  .proof {
    background-color: var(--color-bg-light-card);
    border-top: 1px solid var(--color-border-light);
    border-bottom: 1px solid var(--color-border-light);
    overflow: hidden;
  }

  .section-header {
    text-align: center;
    max-width: 650px;
    margin: 0 auto 3.5rem;
  }

  .sub-title {
    font-family: var(--font-headings);
    color: var(--color-primary);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: inline-block;
    margin-bottom: 0.5rem;
  }

  .main-title {
    font-size: clamp(1.8rem, 3.5vw, 2.5rem);
    color: var(--color-text-light-primary);
    letter-spacing: -0.02em;
  }

  /* Metrics Grid */
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.25rem;
    margin-bottom: 3.5rem;
  }

  .metric-card {
    background: #ffffff;
    border: 1px solid var(--color-border-light);
    border-radius: 16px;
    padding: 2.25rem 1.25rem;
    text-align: center;
    transition: var(--transition-smooth);
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow: var(--shadow-sm);
  }

  .metric-card:hover {
    transform: translateY(-4px);
    border-color: rgba(59, 130, 246, 0.2);
    box-shadow: 0 15px 30px rgba(59, 130, 246, 0.04), var(--shadow-md);
  }

  .metric-visual {
    font-family: var(--font-headings);
    font-size: clamp(1.8rem, 2.5vw, 2.4rem);
    font-weight: 800;
    line-height: 1.1;
    background: var(--gradient-blue-cyan);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 0.75rem;
  }

  .metric-visual.text-small {
    font-size: clamp(1.5rem, 2.2vw, 2.1rem);
  }

  .metric-visual.text-smaller {
    font-size: clamp(1.3rem, 1.8vw, 1.65rem);
  }

  .metric-divider {
    width: 2rem;
    height: 2px;
    background: rgba(59, 130, 246, 0.2);
    margin-bottom: 0.75rem;
    border-radius: 1px;
    transition: var(--transition-smooth);
  }

  .metric-card:hover .metric-divider {
    width: 3.5rem;
    background: var(--color-primary);
  }

  .metric-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-light-secondary);
    line-height: 1.4;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  /* Bottom summary copy */
  .proof-summary {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }

  .summary-text {
    font-size: 1.15rem;
    color: var(--color-text-light-primary);
    font-weight: 500;
    line-height: 1.6;
  }

  /* Responsive break points */
  @media (max-width: 992px) {
    .metrics-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 640px) {
    .metrics-grid {
      grid-template-columns: 1fr;
    }
    .metric-card {
      padding: 1.75rem 1.5rem;
    }
    .full-width-mobile {
      grid-column: span 1;
    }
  }
</style>
